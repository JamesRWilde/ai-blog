	transform: translateY(-30px);
}
.hm-com-lotties:has(.hm-levels-tab.is-3.is-open) .hm-com-lottie.is-3{
	transform: translateY(30px);
}
.hm-com-lotties:has(.hm-levels-tab.is-3.is-open) .hm_level_02-arrows-image{
	transform: translateY(-30px);
}

.hm-com-lotties:has(.hm-levels-tab.is-04.is-open) .hm-com-lottie.is-1{
	transform: translateY(-30px);
}
.hm-com-lotties:has(.hm-levels-tab.is-04.is-open) .hm-com-lottie.is-2{
	transform: translateY(-30px);
}
.hm-com-lotties:has(.hm-levels-tab.is-04.is-open) .hm-com-lottie.is-3{
	transform: translateY(-30px);
}
.hm-com-lotties:has(.hm-levels-tab.is-04.is-open) .hm-com-lottie.is-4{
	transform: translateY(30px);
}
.hm-com-lotties:has(.hm-levels-tab.is-04.is-open) .hm_level_02-arrows-image{
	transform: translateY(-30px);
}

</style></div><div class="cc-card-hovers w-embed"><style>
.card-hover-trigger{
	width: calc(100% / 4);
  background-color: #CED2CB;
}
.card-hover-trigger .card-hover-button-wr{
	opacity: 0;
  transition: opacity 500ms ease;
  transition-delay: 0ms;
}
.card-hover-trigger .card-hover-image-wr{
	opacity: 0;
  transition: opacity 0ms ease;
  transition-delay: 0ms;
}
.card-hover-trigger .card-hover-arrow{
	opacity: 1;
  transition: opacity 500ms ease;
  transition-delay: 0ms;
}
.card-hover-trigger .card-hover-company,
.card-hover-trigger .card-hover-model{
	color: #181717;
}
.card-hover-trigger.is-active{
	width: 100%;
  max-width: 36.875rem;
  background-color: #000000;
}

.card-hover-trigger.is-active .card-hover-company{
	color: #CEEB13;
  opacity: 1;
}
.card-hover-trigger.is-active .card-hover-model{
	color: #fff;
  font-size: 5rem;
}
.card-hover-trigger.is-active .card-hover-arrow{
	opacity: 0;
  transition: opacity 500ms ease;
  transition-delay: 500ms;
}
.card-hover-trigger.is-active .card-hover-button-wr{
	opacity: 1;
  transition: opacity 500ms ease;
	transition-delay: 500ms;
}
.card-hover-trigger.is-active .card-hover-image-wr{
	opacity: 1;
  transition: opacity 500ms ease;
  transition-delay: 500ms;
}


@media screen and (max-width: 922px) {
  .card-hover-trigger{
    width: 100%;
  }
}
</style></div></div><nav data-wf--navbar--variant="dark" class="header-wr"><div class="nav-styles w-embed"><style>
body:has(.nav__menu-button.is-open) .nav__banner.show{
	display: none!important;
}

#header .header__bg{
	opacity: 0;
}
#header.scroll .header__bg{
	opacity: 1;
}
#header.scroll{
	border-color: #181717;
}
#header .header__brand,
#header .nav-link,
#header .nav__dd-trigger{
	color: #fff;
}
#header .nav__dd_link{
	color: #fff;
}
[data-wf--navbar--variant="dark"] #header .header__brand,
[data-wf--navbar--variant="dark"] #header .nav-link,
[data-wf--navbar--variant="dark"] #header .nav__dd-trigger,
[data-wf--navbar--variant="dark"] #header .nav__dd_link,
[data-wf--navbar--variant="dark"] #header .nav__dd_link-single{
	color: #000;
}
[data-wf--navbar--variant="dark"] #header.scroll .header__brand,
[data-wf--navbar--variant="dark"] #header.scroll .nav-link,
[data-wf--navbar--variant="dark"] #header.scroll .nav__dd-trigger,
[data-wf--navbar--variant="dark"] #header.scroll .nav__dd_link,
[data-wf--navbar--variant="dark"] #header.scroll .nav__dd_link-single{
	color: #fff;
}
#header.scroll .header__bg,
#header:has(.nav__dd-trigger.w--open) .header__bg {  
  opacity: 1;  
}
#header:has(.nav__dd-trigger.w--open) .nav-overlay{
	opacity: .4;
  pointer-events: auto;
}
.nav__dd-trigger.w--open .nav__dd_arrow {
	 transform: rotateZ(180deg);
}

/*#header.scroll #is-login,
#header:has(.nav__dd-trigger.w--open) #is-login,
#header.scroll .button.is-secondary.button-nav_signup,
#header:has(.nav__dd-trigger.w--open) .button.is-secondary.button-nav_signup{
	background-color: #fff;
  color: #181717;
}*/
#header:has(.nav__dd-trigger.w--open) .button.is-gh,
#header.scroll .button.is-gh{
	border-color: #fff;
  color: #fff;
}
#header:has(.nav__dd-trigger.w--open) .button.is-gh:hover,
#header.scroll .button.is-gh:hover{
	border-color: #a3a3a3;
  color: #fff;
}
[data-wf--navbar--variant="dark"] #header:has(.nav__dd-trigger.w--open) .button.is-gh:hover,
[data-wf--navbar--variant="dark"] #header.scroll .button.is-gh:hover{
	border-color: #565859;
  color: #fff;
}
#header .nav__dd_link:hover{
	background-color: #CEEB13;
  color: #181717;
}

[data-wf--navbar--variant="dark"] #header:has(.nav__dd-trigger.w--open) .header__brand,
[data-wf--navbar--variant="dark"] #header:has(.nav__dd-trigger.w--open) .nav-link,
[data-wf--navbar--variant="dark"] #header:has(.nav__dd-trigger.w--open) .nav__dd-trigger,
[data-wf--navbar--variant="dark"] #header:has(.nav__dd-trigger.w--open) .nav__dd_link,
[data-wf--navbar--variant="dark"] #header:has(.nav__dd-trigger.w--open) .nav__dd_link-single{
	color: #fff;
}
[data-wf--navbar--variant="dark"] #header:has(.nav__dd-trigger.w--open) .nav__dd_link:hover{
	color: #181717;
}
[data-wf--navbar--variant="dark"] #header:has(.nav__menu-button.is-open) .header__brand,
[data-wf--navbar--variant="dark"] #header:has(.nav__menu-button.is-open) .nav-link,
[data-wf--navbar--variant="dark"] #header:has(.nav__menu-button.is-open) .nav__dd-trigger,
[data-wf--navbar--variant="dark"] #header:has(.nav__menu-button.is-open) .nav__dd_link,
[data-wf--navbar--variant="dark"] #header:has(.nav__dd-trigger.w--open) .nav__dd_link-single{
	color: #fff;
}

[data-wf--navbar--variant="dark"] .nav__menu-button.is-open .nav-line{
	background-color: #fff!important;
}
[data-wf--navbar--variant="dark"] #header.scroll .nav__menu-button .nav-line{
	background-color: #fff!important;
}

.nav__menu-list::-webkit-scrollbar {
  width: 0px;
}
.nav__menu-list::-webkit-scrollbar-track {
  background: transparent;
}
.nav__menu-list::-webkit-scrollbar-thumb {
  background: transparent;
}
.nav__menu-list::-webkit-scrollbar-thumb:hover {
  background: transparent;
}
.nav__dd_link:last-child{
	border: none;
}

.sub_dd-nav:has(.sub_dd-nav-tg.w--open){
	background-color: #CEEB13;
}
.sub_dd-nav:has(.sub_dd-nav-tg.w--open) .sub_dd-nav-tg{
	color: #181717;
}
.sub_dd-nav .nav__dd_arrow-nest{
	transform: rotateZ(-90deg);
}
.sub_dd-nav:has(.sub_dd-nav-tg.w--open) .nav__dd_arrow-nest{
	transform: rotateZ(0deg);
}


@media screen and (min-width: 1024px) {
	.nav__dd_link-single .nav__dd_link-text{
    position: relative;
    display: inline-block; 
  }

  .nav__dd_link-single .nav__dd_link-text::after{
    content: "";
    position: absolute;
    left: 0;
    bottom: -2px;
    width: 100%;
    height: 1px;
    background: #fff;

    transform: scaleX(0);
    transform-origin: left;
    transition: transform 250ms ease;
  }

  .nav__dd_link-single:hover .nav__dd_link-text::after{
    transform: scaleX(1);
  }

  .nav__dd_link-single:focus-within .nav__dd_link-text::after{
    transform: scaleX(1);
  }
  
  [data-wf--navbar--variant="dark"] .nav__dd_link-single .nav__dd_link-text::after{
  	background: #000;
  }
}
@media screen and (max-width: 1024px) {
	#header .nav__menu-list{
  	display: block;
    transform: translateY(-10px);
    opacity: 0;
    visibility: hidden;
    pointer-events: none;
    transition: transform 500ms ease, opacity 500ms ease, visibility 0s linear 500ms;
  }
	#header:has(.nav__menu-button.is-open) .nav__menu-list{
		transform: translateY(0);
    opacity: 1;
    visibility: visible;
    pointer-events: auto;
    transition: transform 500ms ease, opacity 500ms ease;
	}
}
@media screen and (min-width: 1024px) and (max-width: 1152px) {
	.nav-link,
  .nav__dd-trigger,
  .nav__dd_link-single{
  	padding-left: 0.5rem;
    padding-right: 0.5rem
  }
  .nav__dd-trigger,
  .nav__dd_link-single{
  	font-size: 0.725rem;
  }
}
@media screen and (min-width: 992px) and (max-width: 1024px) {
	.nav__menu-button{
		display: flex;
	}
  .nav__menu-list{
  	display: none;
    z-index: 10;
    background-color: var(--black);
    width: 100%;
    max-height: 100dvh;
    padding-top: 3.75rem;
    position: fixed;
    inset: 0% 0% auto;
  }
  .header__container{
  	height: 4.5rem;
  }
  .nav__menu {
    border-top-style: solid;
    border-top-width: 1px;
    border-top-color: var(--colors--white);
    flex-flow: column;
    max-height: calc(100dvh - 52px);
    padding-top: 2.5rem;
    overflow: auto;
  }
  .nav__dd {
    border-bottom: 1px solid var(--stone-grey);
    width: 100%;
  }
  .nav__dd-trigger {
    justify-content: space-between;
    align-items: center;
    padding: 1.188rem 1.25rem;
  }
  .nav__dd-content.w--open {
    background-color: #18171700;
    padding-bottom: 1rem;
    position: relative;
    top: 0;
    left: 0;
  }
  #header .nav__dd_link {
    color: #CED2CB;
  }
  .nav__dd_link-single {
    text-align: left;
    justify-content: flex-start;
    align-items: center;
    padding: 1.188rem 1.25rem;
  }
  .nav__dd-single{
  	border-bottom: 1px solid #a3a3a3!important;
  }
  [data-wf--navbar--variant="dark"] #header .nav__dd_link-single {
    color: #fff;
  }
  .header__container{
  	height: 4.5rem;
  }
  .header__brand {
    z-index: 12;
    position: relative;
  }
  .nav__list-item.is-buttons{
  	padding-top: 2.5rem;
    padding-bottom: 1.5rem;
            justify-content: flex-start;
  }
  [data-wf--navbar--variant="dark"] .button.is-gh{
  	border-color: #fff;
    color: #fff;
  }
}
@media screen and (max-width: 991px) {
  #header .nav-link:hover{
  	background-color: #181717;
    color: #fff;
  }
  [data-wf--navbar--variant="dark"] #header .nav__dd_link{
  	color: #D1D1D1;
  }
  [data-wf--navbar--variant="dark"] #header .nav__dd_link:hover{
  	color: #D1D1D1;
  }
  [data-wf--navbar--variant="dark"] #header .nav__dd_link-single{
  	color: #fff;
  }
  /*#is-login,
  #is-login,
  .button.is-secondary.button-nav_signup,
  .button.is-secondary.button-nav_signup{
    background-color: #fff;
    color: #181717;
  }*/
  #header .nav__dd_link{
    color: #CED2CB;
  }
}
  

<script>
  $(document).ready(function () {
    if ($(".plus-minus").length === 0) return;

    $(".plus-minus").on("click", function () {
      const $wrapper = $(this).closest(".dropdown-global-wr");

      if ($wrapper.length === 0) return;

      const $toggle = $wrapper.find(".dropdown-toggle-global.w--open");

      if ($toggle.length) {
        const $dropdown = $wrapper.find(".dropdown-global");
        if ($dropdown.length) {
          $dropdown.trigger("w-close");
        }
      }
    });
  });
</script>

<script>
  window.addEventListener("scroll", function () {
    const header = document.getElementById("header");
    if (window.scrollY > 0) {
      header.classList.add("scroll");
    } else {
      header.classList.remove("scroll");
    }
  });

  document.addEventListener("DOMContentLoaded", () => {
    const menuButton = document.querySelector(".nav__menu-button");
    if (!menuButton) return;

    const line1 = menuButton.querySelector(".nav-line.is-1");
    const line2 = menuButton.querySelector(".nav-line.is-2");
    const line3 = menuButton.querySelector(".nav-line.is-3");
    if (!line1 || !line2 || !line3) return;

    gsap.set([line1, line2, line3], { transformOrigin: "50% 50%" });

    const tl = gsap.timeline({ paused: true });

    tl.to(line1, { y: 5, duration: 0.25, ease: "power2.out" }, 0)
      .to(line3, { y: -5, duration: 0.25, ease: "power2.out" }, 0)
      .set(line2, { opacity: 0 }, 0.25)
      .to(line1, { rotation: 45, duration: 0.25, ease: "power2.out" }, 0.25)
      .to(line3, { rotation: -45, duration: 0.25, ease: "power2.out" }, 0.25);

    if (menuButton.classList.contains("is-open")) tl.progress(1);

    menuButton.addEventListener("click", () => {
      const willOpen = !menuButton.classList.contains("is-open");
      menuButton.classList.toggle("is-open", willOpen);

      if (willOpen) tl.play();
      else tl.reverse();
    });

    window.addEventListener("resize", () => {
      if (window.innerWidth > 1024) {
        menuButton.classList.remove("is-open");
        tl.pause(0); 
      }
    });
  });
</script>

<script>
  var utmParams = [
    "utm_source",
    "utm_medium",
    "utm_campaign",
    "utm_term",
    "utm_content",
    "utm_id",
    "gclid",
  ];
  // ===============================
  // CONFIG
  // ===============================

  // const INTERNAL_DOMAINS = ["crusoe.ai", "www.crusoe.ai", "crusoe.com", "www.crusoe.com", "crusoe-staging.webflow.io"];

  const CTA_DOMAINS = [
    "crusoecloud.com",
    "console.crusoecloud.com",
    "console.crusoe.ai",
    "console.crusoe.com",
  ];

  const PARAM_EXPIRY = 90 * 24 * 60 * 60 * 1000; // 90 days (ms)
  //const PARAM_EXPIRY = 2 * 60 * 1000; // 2 min
  const STORAGE_KEY = "crusoe_saved_params";

  // ===============================
  // HELPERS
  // ===============================

  const excludeParams = ["category", "name"];

  function getUrlParams() {
    const params = {};
    const qs = new URLSearchParams(window.location.search);
    qs.forEach((value, key) => {
      if (!excludeParams.includes(key)) {
        params[key] = value;
      }
    });
    return params;
  }

  function loadParams() {
    const data = localStorage.getItem(STORAGE_KEY);
    return data ? JSON.parse(data) : {};
  }

  function saveParams(obj) {
    localStorage.setItem(STORAGE_KEY, JSON.stringify(obj));

    utmParams.forEach(function (param) {
      if (obj[param] !== undefined) {
        localStorage.setItem(param, obj[param].value);
      } else {
        localStorage.removeItem(param);
      }
    });
  }

  // ===============================
  // 1️⃣ CAPTURE / UPDATE PARAMS
  // ===============================
  // RULES:
  // - If NEW param → add with current timestamp
  // - If SAME param but NEW value → update value + timestamp
  // - If SAME param and SAME value → do NOT update timestamp

  function processIncomingParams() {
    const incoming = getUrlParams();
    if (!Object.keys(incoming).length) return;

    const saved = loadParams();
    const now = Date.now();

    Object.entries(incoming).forEach(([key, value]) => {
      const existing = saved[key];

      if (!existing) {
        // New param entirely
        saved[key] = { value, firstSeen: now };
      } else if (existing.value !== value) {
        // Param reappears with NEW VALUE → update
        saved[key] = { value, firstSeen: now };
      }
      // If same value → do nothing (keep original timestamp)
    });

    saveParams(saved);
  }

  // ===============================
  // 2️⃣ REMOVE PARAMS OLDER THAN 90 DAYS (unless updated)
  // ===============================

  function getValidParams() {
    const saved = loadParams();
    const now = Date.now();

    const valid = {};
    const cleaned = {};

    Object.entries(saved).forEach(([key, obj]) => {
      if (!excludeParams.includes(key) && now - obj.firstSeen <= PARAM_EXPIRY) {
        valid[key] = obj.value;
        cleaned[key] = obj;
      }
    });
    saveParams(cleaned);
    return valid;
  }

  // ===============================
  // 4️⃣ APPEND PARAMS TO INTERNAL + CTA DOMAIN LINKS
  // ===============================

  function updateLinks(params) {
    const links = document.querySelectorAll("a[href]");

    links.forEach((link) => {
      const href = link.getAttribute("href");

      // Skip empty, hash links, or mailto
      if (
        !href ||
        href.startsWith("#") ||
        href.startsWith("mailto:") ||
        href.startsWith("?")
      )
        return;

      let url;
      try {
        url = new URL(href, window.location.origin);
      } catch (e) {
        return;
      }

      // const isInternal = INTERNAL_DOMAINS.includes(url.hostname);

      const isCTA = CTA_DOMAINS.some(
        (domain) =>
          url.hostname === domain || url.hostname.endsWith("." + domain)
      );

      // if (isInternal || isCTA) {
      if (isCTA) {
        Object.entries(params).forEach(([key, value]) => {
          url.searchParams.set(key, value);
        });
        link.href = url.toString();
      }
    });

    Object.entries(params).forEach(([key, value]) => {
      if (utmParams.includes(key)) {
        if (value) {
          var inputs = document.querySelectorAll(
            'input[type="hidden"][name="' + key + '"]'
          );
          for (var i = 0; i < inputs.length; i++) {
            inputs[i].value = value;
          }
        }
      }
    });
  }

  // ===============================
  // MAIN EXECUTION
  // ===============================

  function initParamsAddScript() {
    processIncomingParams(); // update timestamps on changed values
    const valid = getValidParams(); // keep only <90 days
    // updateCurrentPageUrl(valid);
    updateLinks(valid);
  }

  document.addEventListener("DOMContentLoaded", function () {
    const valid = getValidParams();
    updateLinks(valid);
  });

  window.fsAttributes = window.fsAttributes || [];
  window.fsAttributes.push([
    "cmsload",
    (listInstances) => {
      setTimeout(() => {
        initParamsAddScript();
      }, 1000);

      // Run each time pagination loads more items
      listInstances.forEach((listInstance) => {
        listInstance.on("renderitems", () => {
          initParamsAddScript();
        });
      });
    },
  ]);

  (function () {
    initParamsAddScript();
  })();
</script></body></html>
    <!-- Theme bootstrap: apply stored theme class BEFORE first paint to avoid flash -->
    <script>
      (function(){
        try {
          var stored = localStorage.getItem('krater-theme-v2');
          var theme = stored === 'light' ? 'light' : stored === 'dark' ? 'dark' : null;
          if (!theme) {
            theme = window.matchMedia('(prefers-color-scheme: light)').matches ? 'light' : 'dark';
          }
          document.documentElement.classList.add(theme);
        } catch(e){}
      })();
    </script>
    <!-- Inline critical CSS for initial paint + LCP pre-render -->
    <style>
      #root-loader {
        position: fixed;
        inset: 0;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
      }
      /* Theme-aware colors via class on <html> */
      .dark #root-loader { background: #121212; }
      .light #root-loader { background: #ffffff; }
      /* Fallback if no class yet (media query) */
      #root-loader { background: #121212; }
      @media (prefers-color-scheme: light) {
        #root-loader { background: #ffffff; }
      }
      #root-loader .boot-logo {
        width: 48px;
        height: 48px;
        border-radius: 12px;
        animation: logo-pulse 1.5s ease-in-out infinite, scale-in 0.2s ease-out;
      }
      .dark #root-loader .boot-logo-light { display: block; }
      .dark #root-loader .boot-logo-dark { display: none; }
      .light #root-loader .boot-logo-light { display: none; }
      .light #root-loader .boot-logo-dark { display: block; }
      /* Fallback (no class yet) */
      #root-loader .boot-logo-light { display: block; }
      #root-loader .boot-logo-dark { display: none; }
      @media (prefers-color-scheme: light) {
        #root-loader .boot-logo-light { display: none; }
        #root-loader .boot-logo-dark { display: block; }
      }
      @keyframes logo-pulse {
        0%, 100% { opacity: 1; transform: scale(1); }
        50% { opacity: 0.7; transform: scale(0.95); }
      }
      @keyframes scale-in {
        0% { transform: scale(0.95); opacity: 0; }
        100% { transform: scale(1); opacity: 1; }
      }
    </style>
